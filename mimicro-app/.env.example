# Copia este archivo como .env y completa los valores
# cp .env.example .env

# PostgreSQL — cambia TU_CONTRASEÑA por la que pusiste al instalar PostgreSQL
DATABASE_URL=postgresql://postgres:TU_CONTRASEÑA@localhost:5432/mimicro_db

# Redis — si usas la instalación por defecto no necesitas cambiar esto
REDIS_URL=redis://localhost:6379

# JWT — cambia esto por cualquier string largo y aleatorio
JWT_SECRET=cambia_esto_por_una_clave_secreta_muy_larga_2026

JWT_EXPIRES_DAYS=7
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:19006
LOG_FILE=security.log
